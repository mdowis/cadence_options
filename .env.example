# Tradier
# Sandbox and production have separate API tokens and account IDs.
# TRADIER_ENV selects which credentials are used.
TRADIER_ENV=sandbox

# Sandbox credentials (https://developer.tradier.com/ -> sandbox account)
TRADIER_SANDBOX_ACCESS_TOKEN=
TRADIER_SANDBOX_ACCOUNT_ID=

# Production credentials (real money, live orders)
TRADIER_PRODUCTION_ACCESS_TOKEN=
TRADIER_PRODUCTION_ACCOUNT_ID=

# Legacy single-token variables (fallback when {ENV}-specific vars
# above are empty). If you're only using one environment, setting
# these is fine.
TRADIER_ACCESS_TOKEN=
TRADIER_ACCOUNT_ID=

# Strategy
CADENCE_SYMBOLS=SPY,QQQ
CADENCE_TARGET_DTE=45
CADENCE_TARGET_DELTA=16
CADENCE_WING_WIDTH=10
CADENCE_MIN_IV_RANK=30
CADENCE_MIN_CREDIT_PCT=20
CADENCE_PROFIT_TARGET_PCT=50
CADENCE_TIME_STOP_DTE=21
CADENCE_LOSS_STOP_MULTIPLIER=2

# Risk
CADENCE_MAX_DRAWDOWN_PCT=10
CADENCE_DRAWDOWN_REFERENCE=session_start
CADENCE_MAX_PER_POSITION_PCT=2
CADENCE_USE_KELLY=false
CADENCE_KELLY_FRACTION=0.25
CADENCE_MAX_CONCURRENT_POSITIONS=5
CADENCE_MAX_PORTFOLIO_DELTA=5000
CADENCE_MAX_PORTFOLIO_VEGA=500

# Dashboard
CADENCE_PORT=8050
CADENCE_STATE_FILE=risk_state.json
CADENCE_TRACKER_STATE_FILE=position_tracker.json
CADENCE_AUTOSTART_SCANNER=true

# Telegram (optional)
CADENCE_TELEGRAM_BOT_TOKEN=
CADENCE_TELEGRAM_CHAT_ID=
CADENCE_TELEGRAM_COMMANDS_ENABLED=false
CADENCE_TELEGRAM_STATUS_INTERVAL=3600
